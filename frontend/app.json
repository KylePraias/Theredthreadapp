{
  "expo": {
    "name": "RedThread",
    "slug": "redthread",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "redthread",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.kylepraias.redthread",
      "supportsTablet": true
    },
    "android": {
      "package": "com.kylepraias.redthread",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow RedThread to use your location to find nearby events."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cb87dacf-49f3-4f08-8839-e9c50c51856f"
      },
      "googleMapsApiKey": "AIzaSyC7Ed_SKD9HULQs5MOkeZ5myl2buzv6Sog"
    }
  }
}